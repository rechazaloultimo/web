            altText=" "
            width={1900}
            height={1900}
          />
          <CardGaleria
            imgPath="microscopios/micro (5).webp"
            altText=" "
            width={1900}
            height={1900}
          />
          <CardGaleria
            imgPath="microscopios/micro (6).webp"
            altText=" "
