---
// src/components/quizzes/QuizDisplay.astro
import type { QuizMeta } from "../../data/quizzes";

export interface Props {
  quizzes: QuizMeta[];
}

const { quizzes } = Astro.props;
---

<div id="quiz-controller-wrapper" class="section-bg-paper container mx-auto px-4 max-w-5xl">
  <div id="no-quiz-placeholder" class="text-center py-20 border border-dashed border-gray-300">
    <h3 class="font-title text-xl text-gray-400 uppercase tracking-widest">
      Selecciona un módulo para comenzar
    </h3>
  </div>

  <div id="active-quiz-container" style="display: none;">
    <div class="quiz-card-full">
      <div class="quiz-header-custom">
        <h1 id="dynamic-quiz-title-text" class="font-title text-3xl"></h1>
        <div class="sub uppercase tracking-tighter opacity-70">Protocolo de Evaluación Técnica</div>
      </div>
      <div id="quiz-engine-mount"></div>
    </div>
  </div>
</div>

<script define:vars={{ quizzes }}>
  function runQuizEngine() {
    const urlParams = new URLSearchParams(window.location.search);
    const activeId = urlParams.get("quiz");
    const engineMount = document.getElementById("quiz-engine-mount");
    const selectedQuiz = quizzes.find((q) => q.id === activeId);

    if (!selectedQuiz) return;

    document.getElementById("active-quiz-container").style.display = "block";
    document.getElementById("no-quiz-placeholder").style.display = "none";
    document.getElementById("dynamic-quiz-title-text").innerText = selectedQuiz.title;

    // --- VARIABLES DE SESIÓN (Valores por defecto) ---
    let SECONDS_PER_QUESTION = 9;
    let IS_RANDOM = false; // "Original" por defecto ahora
    const TRANSITION_DELAY = 2000;

    let currentSet = [];
    let currentIndex = 0;
    let userAnswers = [];
    let liveAciertos = 0;
    let liveErrores = 0;
    let liveSinContestar = 0;
    let timerInterval = null;
    let transitionTimeout = null;
    let timeLeft = 0;

    function renderSetup() {
      stopTimers();
      engineMount.innerHTML = `
        <div class="fade-in setup-screen" style="padding: 3rem 1rem; max-width: 600px; margin: 0 auto;">
          <h2 style="font-family: serif; font-size: 1.6rem; text-align: center; margin-bottom: 2.5rem; color: #1a1a1a;">
            Configuración de la Sesión
          </h2>
          
          <div style="display: flex; flex-direction: column; gap: 2rem;">
            
            <div class="setup-group">
              <span class="setup-label">Secuencia de Preguntas</span>
              <div class="radio-stack">
                <label class="radio-option">
                  <input type="radio" name="order-mode" value="fixed" checked>
                  <div class="radio-text">
                    <strong>Orden Original</strong>
                    <span>Para aprender secuencialmente los contenidos.</span>
                  </div>
                </label>
                <label class="radio-option">
                  <input type="radio" name="order-mode" value="random">
                  <div class="radio-text">
                    <strong>Orden Aleatorio</strong>
                    <span>Para practicar con un conocimiento básico sólido.</span>
                  </div>
                </label>
              </div>
            </div>

            <div class="setup-group">
              <span class="setup-label">Velocidad de Respuesta</span>
              <div class="radio-stack">
                <label class="radio-option">
                  <input type="radio" name="speed-mode" value="15">
                  <div class="radio-text">
                    <strong>15 Segundos</strong>
                    <span>Modo aprendizaje: lectura pausada y reflexión.</span>
                  </div>
                </label>
                <label class="radio-option">
                  <input type="radio" name="speed-mode" value="9" checked>
                  <div class="radio-text">
                    <strong>9 Segundos</strong>
                    <span>Ritmo estándar: flujo normal de evaluación.</span>
                  </div>
                </label>
                <label class="radio-option">
                  <input type="radio" name="speed-mode" value="5">
                  <div class="radio-text">
                    <strong>5 Segundos</strong>
                    <span>Maestría: para fijar el conocimiento mediante reflejos.</span>
                  </div>
                </label>
              </div>
            </div>

          </div>

          <button id="start-quiz-btn" class="btn-primary-chinese" style="margin-top: 3.5rem; width: 100%;">
            Comenzar Entrenamiento
          </button>
        </div>
      `;

      document.getElementById("start-quiz-btn").addEventListener("click", () => {
        // Capturar Tiempo
        const speedVal = document.querySelector('input[name="speed-mode"]:checked').value;
        SECONDS_PER_QUESTION = parseInt(speedVal);

        // Capturar Orden
        const orderVal = document.querySelector('input[name="order-mode"]:checked').value;
        IS_RANDOM = orderVal === "random";

        prepareAndStart();
      });
    }

    function prepareAndStart() {
      let baseSet = [...selectedQuiz.questions];
      if (IS_RANDOM) baseSet.sort(() => Math.random() - 0.5);

      currentSet = baseSet.map((q) => ({
        ...q,
        shuffledOptions: q.options
          .map((opt, i) => ({ text: opt, originalIndex: i }))
          .sort(() => Math.random() - 0.5),
      }));

      currentIndex = 0;
      userAnswers = [];
      liveAciertos = 0;
      liveErrores = 0;
      liveSinContestar = 0;
      renderQuestion();
    }

    // --- LÓGICA DE MOTOR (IDÉNTICA A LA ANTERIOR PERO CON UI LIMPIA) ---
    function stopTimers() {
      if (timerInterval) clearInterval(timerInterval);
      if (transitionTimeout) clearTimeout(transitionTimeout);
    }

    function startTimer() {
      stopTimers();
      timeLeft = SECONDS_PER_QUESTION;
      updateTimerUI();
      timerInterval = setInterval(() => {
        timeLeft--;
        updateTimerUI();
        if (timeLeft < 0) {
          clearInterval(timerInterval);
          handleAutoSkip();
        }
      }, 1000);
    }

    function updateTimerUI() {
      const bar = document.getElementById("timer-bar-element");
      if (bar) {
        const percentage = Math.max(0, (timeLeft / SECONDS_PER_QUESTION) * 100);
        bar.style.width = `${percentage}%`;
        // Cambio de color si queda poco tiempo
        bar.style.backgroundColor = timeLeft < 3 ? "#b31010" : "#1a1a1a";
      }
    }
    function renderQuestion() {
      const q = currentSet[currentIndex];
      engineMount.innerHTML = `
        <div class="fade-in">
          <div class="progress-area">
            <div style="display: flex; flex-direction: column; gap: 0.2rem;">
               <span style="font-weight: bold; text-transform: uppercase; font-size: 0.7rem; color: #888;">
                Módulo en curso
               </span>
               <span style="font-family: serif; font-size: 1rem; color: var(--color-text-title);">
                Pregunta ${currentIndex + 1} de ${currentSet.length}
               </span>
            </div>
            
            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
              <span class="score-badge">✅ ${liveAciertos}</span>
              <span class="incorrect-badge">❌ ${liveErrores}</span>
              <span class="unanswered-badge">⚪ ${liveSinContestar}</span>
            </div>
          </div>
          
          <div class="timer-container">
            <div id="timer-bar-element" class="timer-bar"></div>
          </div>

          <div class="question-body">
            <h2 class="question-text">${q.text}</h2>
            
            <div class="options-container">
              ${q.shuffledOptions
                .map(
                  (opt, i) => `
                <button class="opt-btn" data-idx="${opt.originalIndex}">
                  <span class="opt-btn-indicator">${String.fromCharCode(65 + i)}</span>
                  <span>${opt.text}</span>
                </button>
              `,
                )
                .join("")}
            </div>
            <div id="feedback-anchor"></div>
          </div>
        </div>
      `;

      engineMount.querySelectorAll(".opt-btn").forEach((btn) => {
        btn.addEventListener("click", handleSelection);
      });
      startTimer();
    }
    function handleSelection(e) {
      stopTimers();
      const q = currentSet[currentIndex];
      const selectedIdx = parseInt(e.currentTarget.dataset.idx);
      const isRight = selectedIdx === q.correct;

      // Actualizar contadores globales
      if (isRight) liveAciertos++;
      else liveErrores++;

      finalizeQuestion(selectedIdx, isRight);
    }

    function handleAutoSkip() {
      const q = currentSet[currentIndex];
      liveSinContestar++;
      userAnswers.push({
        questionText: q.text,
        selectedText: "TIEMPO AGOTADO",
        correctText: q.options[q.correct],
        isRight: false,
      });

      // Solo marcamos la correcta en verde porque nadie eligió nada
      markButtons(q.correct, -1);
      transitionTimeout = setTimeout(nextStep, TRANSITION_DELAY);
    }

    function finalizeQuestion(selectedIdx, isRight) {
      const q = currentSet[currentIndex];
      userAnswers.push({
        questionText: q.text,
        selectedText: q.options[selectedIdx],
        correctText: q.options[q.correct],
        isRight,
      });

      // Pintamos los botones según la lógica técnica
      markButtons(q.correct, selectedIdx);

      // Transición automática sin mensajes de texto
      transitionTimeout = setTimeout(nextStep, TRANSITION_DELAY);
    }

    function markButtons(correctIdx, selectedIdx) {
      const buttons = engineMount.querySelectorAll(".opt-btn");

      buttons.forEach((btn) => {
        btn.classList.add("is-locked"); // Bloqueamos para evitar doble click
        const idx = parseInt(btn.dataset.idx);

        // 1. Si es la correcta, siempre va en verde (is-correct)
        if (idx === correctIdx) {
          btn.classList.add("is-correct");
        }

        // 2. Si el usuario eligió esta y no es la correcta, va en rojo (is-incorrect)
        if (idx === selectedIdx && idx !== correctIdx) {
          btn.classList.add("is-incorrect");
        }
      });

      // Actualizamos los badges de la cabecera inmediatamente
      updateLiveStats();
    }

    function updateLiveStats() {
      const badgeOk = engineMount.querySelector(".score-badge");
      const badgeErr = engineMount.querySelector(".incorrect-badge");
      const badgeWait = engineMount.querySelector(".unanswered-badge");

      if (badgeOk) badgeOk.innerText = `✅ ${liveAciertos}`;
      if (badgeErr) badgeErr.innerText = `❌ ${liveErrores}`;
      if (badgeWait) badgeWait.innerText = `⚪ ${liveSinContestar}`;
    }

    function showFeedback(msg) {
      document.getElementById("feedback-anchor").innerHTML =
        `<div class="next-notice">${msg} ...</div>`;
    }

    function nextStep() {
      currentIndex++;
      if (currentIndex < currentSet.length) renderQuestion();
      else renderResults();
    }

    function renderResults() {
      stopTimers();
      const score = userAnswers.filter((a) => a.isRight).length;
      const percentage = Math.round((score / currentSet.length) * 100);

      engineMount.innerHTML = `
        <div class="fade-in results-classic" style="text-align: center; padding: 2rem;">
          <div class="score-display" style="font-family: serif; font-size: 4rem; color: var(--color-chinese-seal-red, #b31010); margin-bottom: 0.5rem;">
            ${score} / ${currentSet.length}
          </div>
          <p style="text-transform: uppercase; letter-spacing: 0.2em; font-size: 0.8rem; color: #666; margin-bottom: 2rem;">
            Precisión: ${percentage}%
          </p>
          
          <div class="custom-scrollbar" style="text-align: left; max-height: 600px; overflow-y: auto; background: #fff; padding: 1.5rem; border: 1px solid #eee; margin-bottom: 2rem;">
            <h3 style="font-family: serif; font-size: 1rem; border-bottom: 1px solid #eee; padding-bottom: 0.5rem; margin-bottom: 1.5rem; text-transform: uppercase; letter-spacing: 0.1em;">
              Revisión Técnica
            </h3>
            
            ${userAnswers
              .map(
                (a, i) => `
              <div style="margin-bottom: 1.5rem; border-bottom: 1px dotted #ccc; padding-bottom: 1rem; last-child { border: none; }">
                <p style="margin-bottom: 0.5rem; font-size: 0.95rem; line-height: 1.4;">
                  <strong>${i + 1}. ${a.questionText}</strong>
                </p>
                <div style="font-size: 0.85rem; display: grid; grid-template-columns: 100px 1fr; gap: 0.5rem;">
                  <span style="color: #999; text-transform: uppercase; font-size: 0.65rem; font-weight: bold;">Tu respuesta:</span>
                  <span style="${a.isRight ? "color: #15803d; font-weight: 600;" : "color: var(--color-chinese-seal-red, #b31010); font-weight: 600;"}">
                    ${a.selectedText} ${a.isRight ? "✓" : "✗"}
                  </span>
                  
                  ${
                    !a.isRight
                      ? `
                    <span style="color: #999; text-transform: uppercase; font-size: 0.65rem; font-weight: bold;">Correcta:</span>
                    <span style="color: #333; font-weight: 600;">${a.correctText}</span>
                  `
                      : ""
                  }
                </div>
              </div>
            `,
              )
              .join("")}
          </div>
          
          <button id="finalResetBtn" class="start-btn-classic">
            Nueva Sesión
          </button>
        </div>
      `;

      document.getElementById("finalResetBtn").addEventListener("click", renderSetup);
    }

    renderSetup();
  }

  runQuizEngine();
  document.addEventListener("astro:page-load", runQuizEngine);
</script>
