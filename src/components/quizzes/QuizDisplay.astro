---
// src/components/quizzes/QuizDisplay.astro
import type { QuizMeta } from "../../data/quizzes";

export interface Props {
  quizzes: QuizMeta[];
}

const { quizzes } = Astro.props;
---

<div id="quiz-controller-wrapper" class="section-bg-paper container mx-auto px-4 max-w-5xl">
  <div
    id="no-quiz-placeholder"
    class="group relative p-[2px] rounded-2xl overflow-hidden bg-gradient-to-br from-gray-100 via-gray-200 to-gray-100 transition-all duration-700 hover:from-gray-200 hover:via-gray-300 hover:to-gray-200"
  >
    <div class="bg-white rounded-[14px] py-20 px-6 flex flex-col items-center justify-center">
      <div
        class="w-16 h-16 bg-gray-50 rounded-2xl flex items-center justify-center mb-6 rotate-3 group-hover:rotate-0 transition-transform duration-500 border border-gray-100"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-8 w-8 text-gray-300"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
          ></path>
        </svg>
      </div>
      <h3 class="font-title text-lg text-gray-400 uppercase tracking-widest text-center">
        Preparado para <span class="text-gray-600">aprender</span>?
      </h3>
      <p class="mt-2 text-sm text-gray-400">Selecciona un módulo para generar las preguntas</p>
    </div>
  </div>

  <div id="active-quiz-container" style="display: none;">
    <div class="quiz-card-full section-bg-paper container mx-auto px-4 max-w-5xl">
      <div id="quiz-engine-mount" class="max-w-5xl mx-auto p-2">
</div>
    </div>
  </div>
</div>

<script define:vars={{ quizzes }}>
  function runQuizEngine() {
    const urlParams = new URLSearchParams(window.location.search);
    const activeId = urlParams.get("quiz");
    const engineMount = document.getElementById("quiz-engine-mount");
    const selectedQuiz = quizzes.find((q) => q.id === activeId);

    if (!selectedQuiz) return;

    // Mostramos el contenedor principal, pero la "magia" ocurre en el engineMount
    document.getElementById("active-quiz-container").style.display = "block";
    document.getElementById("no-quiz-placeholder").style.display = "none";

    let SECONDS_PER_QUESTION = 9;
    let IS_RANDOM = false;
    const TRANSITION_DELAY = 2000;

    let currentSet = [];
    let currentIndex = 0;
    let userAnswers = [];
    let liveAciertos = 0;
    let liveErrores = 0;
    let liveSinContestar = 0;
    let timerInterval = null;
    let transitionTimeout = null;
    let timeLeft = 0;
    let isLocked = false; // Nueva bandera para bloquear interacción

    function renderSetup() {
      stopTimers();
      isLocked = false;
      engineMount.innerHTML = `
        <div class="setup-box fade-in">
          <div class="setup-header">
            <span class="setup-label">Configuración de Sesión</span>
            <h1 class="font-title text-2xl uppercase text-black">${selectedQuiz.title}</h1>
          </div>
          
          <div class="setup-body">
            <div class="mb-8">
              <span class="setup-label">Secuencia de Preguntas</span>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-2">
                <label class="opt-btn cursor-pointer">
                  <input type="radio" name="order-mode" value="fixed" checked class="mr-3">
                  <div class="text-xs"><strong>Orden Original</strong></div>
                </label>
                <label class="opt-btn cursor-pointer">
                  <input type="radio" name="order-mode" value="random" class="mr-3">
                  <div class="text-xs"><strong>Orden Aleatorio</strong></div>
                </label>
              </div>
            </div>

            <div class="mb-8">
              <span class="setup-label">Velocidad de Respuesta</span>
              <div class="grid grid-cols-1 gap-3 mt-2">
                <label class="opt-btn cursor-pointer">
                  <input type="radio" name="speed-mode" value="15" class="mr-3">
                  <div class="text-xs"><strong>15 Segundos</strong> (Aprendizaje)</div>
                </label>
                <label class="opt-btn cursor-pointer">
                  <input type="radio" name="speed-mode" value="9" checked class="mr-3">
                  <div class="text-xs"><strong>9 Segundos</strong> (Estándar)</div>
                </label>
                <label class="opt-btn cursor-pointer">
                  <input type="radio" name="speed-mode" value="5" class="mr-3">
                  <div class="text-xs"><strong>5 Segundos</strong> (Maestría)</div>
                </label>
              </div>
            </div>

            <button id="start-quiz-btn" class="restart-btn w-full mt-4">
              Comenzar Entrenamiento
            </button>
          </div>
        </div>
      `;

      document.getElementById("start-quiz-btn").addEventListener("click", () => {
        const speedVal = document.querySelector('input[name="speed-mode"]:checked').value;
        SECONDS_PER_QUESTION = parseInt(speedVal);
        const orderVal = document.querySelector('input[name="order-mode"]:checked').value;
        IS_RANDOM = orderVal === "random";
        prepareAndStart();
      });
    }

    function prepareAndStart() {
      let baseSet = [...selectedQuiz.questions];
      if (IS_RANDOM) baseSet.sort(() => Math.random() - 0.5);

      currentSet = baseSet.map((q) => ({
        ...q,
        shuffledOptions: q.options
          .map((opt, i) => ({ text: opt, originalIndex: i }))
          .sort(() => Math.random() - 0.5),
      }));

      currentIndex = 0;
      userAnswers = [];
      liveAciertos = 0;
      liveErrores = 0;
      liveSinContestar = 0;
      renderQuestion();
    }

    function stopTimers() {
      if (timerInterval) clearInterval(timerInterval);
      if (transitionTimeout) clearTimeout(transitionTimeout);
    }

    function startTimer() {
      stopTimers();
      timeLeft = SECONDS_PER_QUESTION;
      updateTimerUI();
      timerInterval = setInterval(() => {
        timeLeft--;
        updateTimerUI();
        if (timeLeft < 0) {
          clearInterval(timerInterval);
          handleAutoSkip();
        }
      }, 1000);
    }

    function updateTimerUI() {
      const bar = document.getElementById("timer-bar-element");
      if (bar) {
        const percentage = Math.max(0, (timeLeft / SECONDS_PER_QUESTION) * 100);
        bar.style.width = `${percentage}%`;
        bar.style.backgroundColor = timeLeft < 4 ? "var(--quiz-accent)" : "var(--quiz-text-title)";
      }
    }
    
    function renderQuestion() {
      isLocked = false; // Liberamos el bloqueo para la nueva pregunta
      const q = currentSet[currentIndex];
      engineMount.innerHTML = `
        <div class="quiz-card fade-in">
          <div class="quiz-header-custom">
            <span class="sub">Protocolo de Evaluación Técnica</span>
            <h1>${selectedQuiz.title}</h1>
          </div>

          <div class="progress-area">
            <div class="flex flex-col">
               <span class="setup-label" style="margin-bottom:0">Módulo en curso</span>
               <span class="font-serif text-lg text-black">Pregunta ${currentIndex + 1} de ${currentSet.length}</span>
            </div>
            
            <div class="flex gap-2">
              <span class="score-badge">✅ ${liveAciertos}</span>
              <span class="incorrect-badge">❌ ${liveErrores}</span>
              <span class="unanswered-badge">⚪ ${liveSinContestar}</span>
            </div>
          </div>
          
          <div class="timer-container">
            <div id="timer-bar-element" class="timer-bar"></div>
          </div>

          <div class="question-body">
            <h2 class="question-text">${q.text}</h2>
            
            <div class="options-container">
              ${q.shuffledOptions
                .map((opt, i) => `
                <button class="opt-btn" data-idx="${opt.originalIndex}">
                  <span class="opt-btn-indicator">${String.fromCharCode(65 + i)}</span>
                  <span>${opt.text}</span>
                </button>
              `).join("")}
            </div>
            <div id="feedback-anchor"></div>
          </div>
        </div>
      `;

      engineMount.querySelectorAll(".opt-btn").forEach((btn) => {
        btn.addEventListener("click", handleSelection);
      });
      startTimer();
    }

    function handleSelection(e) {
      if (isLocked) return; // CRÍTICO: Si ya se votó, ignorar más clics
      isLocked = true; 
      
      stopTimers();
      const q = currentSet[currentIndex];
      const selectedIdx = parseInt(e.currentTarget.dataset.idx);
      const isRight = selectedIdx === q.correct;

      if (isRight) liveAciertos++;
      else liveErrores++;

      finalizeQuestion(selectedIdx, isRight);
    }

    function handleAutoSkip() {
      if (isLocked) return;
      isLocked = true;
      
      const q = currentSet[currentIndex];
      liveSinContestar++;
      userAnswers.push({
        questionText: q.text,
        selectedText: "TIEMPO AGOTADO",
        correctText: q.options[q.correct],
        isRight: false,
      });

      markButtons(q.correct, -1);
      transitionTimeout = setTimeout(nextStep, TRANSITION_DELAY);
    }

    function finalizeQuestion(selectedIdx, isRight) {
      const q = currentSet[currentIndex];
      userAnswers.push({
        questionText: q.text,
        selectedText: q.options[selectedIdx],
        correctText: q.options[q.correct],
        isRight,
      });

      markButtons(q.correct, selectedIdx);
      transitionTimeout = setTimeout(nextStep, TRANSITION_DELAY);
    }

    function markButtons(correctIdx, selectedIdx) {
      const buttons = engineMount.querySelectorAll(".opt-btn");
      buttons.forEach((btn) => {
        btn.classList.add("is-locked"); // Estilo visual
        const idx = parseInt(btn.dataset.idx);
        if (idx === correctIdx) btn.classList.add("is-correct");
        if (idx === selectedIdx && idx !== correctIdx) btn.classList.add("is-incorrect");
      });
      updateLiveStats();
    }

    function updateLiveStats() {
      const badgeOk = engineMount.querySelector(".score-badge");
      const badgeErr = engineMount.querySelector(".incorrect-badge");
      const badgeWait = engineMount.querySelector(".unanswered-badge");
      if (badgeOk) badgeOk.innerText = `✅ ${liveAciertos}`;
      if (badgeErr) badgeErr.innerText = `❌ ${liveErrores}`;
      if (badgeWait) badgeWait.innerText = `⚪ ${liveSinContestar}`;
    }

    function nextStep() {
      currentIndex++;
      if (currentIndex < currentSet.length) renderQuestion();
      else renderResults();
    }

    function renderResults() {
      stopTimers();
      const score = userAnswers.filter((a) => a.isRight).length;
      const percentage = Math.round((score / currentSet.length) * 100);

      engineMount.innerHTML = `
        <div class="quiz-card fade-in">
          <div class="quiz-header-custom">
            <span class="sub">Evaluación Finalizada</span>
            <h1>Resultados</h1>
          </div>
          
          <div class="p-10 text-center">
            <div class="font-serif text-6xl text-black mb-2">${score} / ${currentSet.length}</div>
            <p class="setup-label">Precisión lograda: ${percentage}%</p>
            
            <div class="custom-scrollbar mt-8 text-left max-h-[400px] overflow-y-auto border border-gray-100 p-4 bg-gray-50 rounded-lg">
              ${userAnswers.map((a, i) => `
                <div class="mb-4 pb-4 border-b border-dotted border-gray-300 last:border-0">
                  <p class="text-sm font-bold mb-2">${i + 1}. ${a.questionText}</p>
                  <div class="grid grid-cols-2 text-xs gap-2">
                    <span class="text-gray-400 uppercase font-bold">Tu respuesta:</span>
                    <span class="${a.isRight ? 'text-green-700' : 'text-red-700'} font-bold">
                      ${a.selectedText} ${a.isRight ? '✓' : '✗'}
                    </span>
                    ${!a.isRight ? `
                      <span class="text-gray-400 uppercase font-bold">Correcta:</span>
                      <span class="text-black font-bold">${a.correctText}</span>
                    ` : ''}
                  </div>
                </div>
              `).join("")}
            </div>
            
            <button id="finalResetBtn" class="restart-btn w-full mt-8">
              Nueva Sesión
            </button>
          </div>
        </div>
      `;

      document.getElementById("finalResetBtn").addEventListener("click", renderSetup);
    }

    renderSetup();
  }

  runQuizEngine();
  document.addEventListener("astro:page-load", runQuizEngine);
</script>